{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|Edit|Write)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$(git rev-parse --show-toplevel)/scripts/codex-format-post-write.mjs\"",
            "commandWindows": "powershell -NoProfile -Command \"$root = git rev-parse --show-toplevel; node (Join-Path $root 'scripts/codex-format-post-write.mjs')\"",
            "timeout": 30,
            "statusMessage": "Formatting changed lines"
          }
        ]
      }
    ]
  }
}
